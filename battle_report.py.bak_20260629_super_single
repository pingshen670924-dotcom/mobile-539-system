        "- \u4fdd\u7559\u539f\u5247\uff1a\u6b63\u5f0f\u9810\u6e2c\u4e0d\u88ab\u540c\u671f\u91cd\u8dd1\u8986\u84cb\uff0c\u91cd\u8dd1\u7d50\u679c\u53ea\u9032\u5feb\u7167\u8868\u4f9b\u6bd4\u5c0d\u3002",
        f"- \u5be6\u969b Top10 \u5e73\u5747\u547d\u4e2d\uff1a{performance.get('top10_avg_hits', '\u5c1a\u7121\u8cc7\u6599')}",
        "",
        "## \u7814\u7a76\u547d\u4e2d KPI",
        f"- \u72c0\u614b\uff1a{research_kpi.get('status', '\u5c1a\u7121\u8cc7\u6599')}",
        f"- \u6b63\u5f0f\u5be6\u7e3e\u6a23\u672c\uff1a{research_kpi.get('settled_samples', 0)} / \u6700\u4f4e\u6a23\u672c {research_kpi.get('minimum_settled_samples', 30)}",
        "- \u539f\u5247\uff1a\u672a\u9054\u6a19\u6216\u6a23\u672c\u4e0d\u8db3\u6642\uff0c\u7981\u6b62\u5ba3\u7a31\u5fc5\u4e2d\u6216\u6b63\u5f0f\u4e3b\u63a8\u3002",
    ])
    for item in research_kpi.get("levels", {}).values():
        lines.append(
            f"- {item.get('label')}\uff1a\u9054\u6a19 {item.get('successes')}/{item.get('settled_samples')} / "
            f"\u901a\u904e\u7387 {item.get('pass_rate')} / \u5e73\u5747\u547d\u4e2d {item.get('average_hits')} / "
            f"95% \u4e0b\u9650 {item.get('wilson_lower_95')}"
        )
    if rolling_adjustment:
        lines.extend([
            "",
            "## 每日檢討後滾動調整",
            f"- 樣本期數：{rolling_adjustment.get('sample_size')}",
            f"- 政策：{rolling_adjustment.get('policy')}",
            "- 升權來源：" + "、".join(item.get("reason", "") for item in rolling_adjustment.get("boosted_reasons", [])[:8]),
            "- 降權來源：" + "、".join(item.get("reason", "") for item in rolling_adjustment.get("penalized_reasons", [])[:8]),
            "- 連續落空號碼：" + fmt_numbers([item.get("number") for item in rolling_adjustment.get("repeated_failed_numbers", [])[:12]]),
        ])
    if rank_calibration.get("settled_periods"):
        lines.extend([
            "",
            "## 預測排名校準檢討",
            f"- 檢查樣本：近 {rank_calibration.get('settled_periods')} 期已結算正式預測",
            f"- 診斷：{rank_calibration.get('diagnosis')}",
            "| 排名區間 | 命中數 | 占比 |",
            "| --- | ---: | ---: |",
        ])
        for item in rank_calibration.get("buckets", {}).values():
            lines.append(f"| {item.get('label')} | {item.get('hits')} | {item.get('rate')} |")
        lines.extend([
            "",
            "### Top11-15 命中來源",
            "| 來源理由 | 次數 | 涉及號碼 |",
            "| --- | ---: | --- |",
        ])
        for reason, stats in sorted(rank_calibration.get("reason_stats", {}).items(), key=lambda row: row[1]["hits"], reverse=True):
            lines.append(f"| {reason} | {stats.get('hits')} | {fmt_numbers(stats.get('numbers', []))} |")
    lines.append("")
    return "\n".join(lines)


