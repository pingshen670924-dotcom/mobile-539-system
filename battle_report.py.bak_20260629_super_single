                "| 避險包 | 號碼 | 信心指標 | 平均暫避分 | 平均誤中 | 完全避開率 |",
                "| --- | --- | ---: | ---: | ---: | ---: |",
            ])
            unlikely_bt_packs = unlikely_bt.get("packs", {}) if isinstance(unlikely_bt, dict) else {}
